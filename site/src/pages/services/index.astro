---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import FAQ from "@/components/FAQ.astro";
import JsonLd from "@/components/JsonLd.astro";
import { serviceCategories } from "@/lib/services";
import { graph, breadcrumb, faqPage } from "@/lib/jsonld";

const faqs = [
  { q: "Why aren't prices on the page?", a: "Most projects vary based on scope and what's already in place. I'd rather quote you a real number after a short call than post a fake range that doesn't fit. Contact me and quotes come back fast." },
  { q: "What's the smallest job you'll take?", a: "Small jobs are welcome, an account-hardening pass, a quick security assessment, a one-page site. If it's something I can help with, I'll help with it." },
  { q: "Do you work remotely?", a: "Yes. Everything here is delivered remotely to clients across the United States. On-site can be arranged for the right engagement." },
  { q: "Can you really build and ship an iOS app?", a: "Yes. I design, build, and publish native iPhone and iPad apps to the App Store, end to end. VA Disability Calc & Track is a live example." },
  { q: "Will I get documentation I can keep?", a: "Yes. Every project ends with a written runbook or handoff in plain language. If you move on, you take it with you." },
  { q: "Do you offer ongoing support?", a: "Yes. Remote on-call support and app maintenance are available on a monthly cadence for businesses and teams." },
];
---
<BaseLayout title="Services, Custom Software & Cybersecurity" description="Bulwark Black services: websites and custom web apps, custom iOS apps, AI and automation, and small-business IT and cybersecurity. Built and supported remotely across the US.">
  <JsonLd slot="head" data={graph(
    breadcrumb([{ name: "Home", path: "/" }, { name: "Services", path: "/services/" }]),
    faqPage(faqs),
  )} />
  <section class="grid-bg bg-bg-primary px-6 py-20">
    <div class="mx-auto max-w-3xl">
      <p class="eyebrow">Services · Remote · US</p>
      <h1 class="mt-3 font-display text-4xl text-ink md:text-6xl">
        Build, secure, ship. <span class="text-accent">Done right the first time.</span>
      </h1>
      <p class="mt-6 text-muted leading-relaxed">
        Websites and custom web apps, native iOS apps, practical AI, and small-business IT and
        cybersecurity, designed, built, and supported by the person who ships the work. If your
        need isn't on the list, ask anyway. Most projects get scoped in a single call.
      </p>
    </div>
  </section>

  <nav class="sticky top-[68px] z-30 border-y border-line bg-bg-primary/90 backdrop-blur">
    <div class="mx-auto flex max-w-6xl flex-wrap gap-x-6 gap-y-2 px-6 py-3 text-xs uppercase tracking-[2px]">
      {serviceCategories.map((c) => (
        <a href={`#${c.slug}`} class="text-muted hover:text-accent" data-cat-link={c.slug}>
          {c.icon} {c.title}
        </a>
      ))}
    </div>
  </nav>

  {serviceCategories.map((cat) => (
    <section id={cat.slug} class="cv-defer scroll-mt-32 bg-bg-secondary px-6 py-20 odd:bg-bg-primary">
      <div class="mx-auto max-w-6xl">
        <SectionHeader
          eyebrow={`${cat.icon} ${cat.items.length} ${cat.items.length === 1 ? "service" : "services"}`}
          title={cat.title}
          subtitle={cat.summary}
        />
        <div class="grid gap-4 md:grid-cols-2">
          {cat.items.map((item) => (
            <article class="border border-accent/15 bg-bg-card p-6 card-lift">
              <h3 class="font-display text-lg text-ink">{item.name}</h3>
              <p class="mt-2 text-sm text-muted leading-relaxed">{item.blurb}</p>
              <ul class="mt-4 flex flex-wrap gap-2">
                {item.tags.map((t) => <li class="chip">{t}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>
  ))}

  <FAQ items={faqs} />

  <section class="bg-bg-primary px-6 py-20 text-center">
    <p class="text-xs uppercase tracking-[3px] text-accent">Don't See What You Need?</p>
    <h2 class="mt-3 font-display text-3xl text-ink md:text-4xl">
      Tell me the outcome. I'll tell you if I can help.
    </h2>
    <div class="mt-8 flex flex-wrap justify-center gap-4">
      <a href="/work-with-me/apply/" class="btn-primary">Work With Me →</a>
      <a href="/contact/" class="btn-ghost">Just say hi</a>
    </div>
  </section>

  <script>
    const links = document.querySelectorAll<HTMLAnchorElement>("[data-cat-link]");
    const targets = Array.from(links).map((l) =>
      document.getElementById(l.dataset.catLink ?? ""),
    );
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (!e.isIntersecting) return;
          links.forEach((l) =>
            l.classList.toggle("text-accent", l.dataset.catLink === e.target.id),
          );
        });
      },
      { rootMargin: "-20% 0px -70% 0px" },
    );
    targets.forEach((t) => t && io.observe(t));
  </script>
</BaseLayout>
