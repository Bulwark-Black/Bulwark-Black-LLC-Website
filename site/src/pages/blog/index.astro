---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

const allPosts: CollectionEntry<"blog">[] = await getCollection("blog");
const posts = allPosts
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
---
<BaseLayout title="Blog" description="Field notes on cybersecurity, OT, and AI in defense.">
  <section class="grid-bg bg-bg-primary px-6 py-20">
    <div class="mx-auto max-w-3xl">
      <p class="text-[11px] uppercase tracking-[3px] text-accent">Blog</p>
      <h1 class="mt-3 font-display text-4xl text-ink md:text-6xl">
        Notes from the <span class="text-accent">field.</span>
      </h1>
    </div>
  </section>

  <section class="bg-bg-secondary px-6 py-20">
    <div class="mx-auto max-w-4xl">
      {posts.length === 0 ? (
        <p class="text-muted">No posts yet, first dispatch coming soon.</p>
      ) : (
        <ul class="space-y-4">
          {posts.map((p) => (
            <li>
              <a href={`/blog/${p.slug}/`} class="block border border-accent/15 bg-bg-card p-6 card-lift">
                <p class="text-xs uppercase tracking-[2px] text-accent">
                  {p.data.publishedAt.toISOString().slice(0, 10)}
                </p>
                <h2 class="mt-2 font-display text-xl text-ink">{p.data.title}</h2>
                <p class="mt-2 text-sm text-muted">{p.data.summary}</p>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
</BaseLayout>
