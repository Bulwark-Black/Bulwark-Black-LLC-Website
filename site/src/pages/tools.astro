---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import JsonLd from "@/components/JsonLd.astro";
import { toolCategories } from "@/lib/tools";
import { graph, breadcrumb } from "@/lib/jsonld";

const totalTools = toolCategories.reduce((n, c) => n + c.tools.length, 0);
const pricingLabel = {
  free: { text: "Free", cls: "border-accent/40 text-accent" },
  freemium: { text: "Freemium", cls: "border-yellow-500/40 text-yellow-400" },
  paid: { text: "Paid", cls: "border-rose-400/40 text-rose-300" },
};
---
<BaseLayout title="Tools" description="What I actually use, software I rely on every day.">
  <JsonLd slot="head" data={graph(
    breadcrumb([{ name: "Home", path: "/" }, { name: "Tools", path: "/tools/" }]),
  )} />
  <section class="grid-bg bg-bg-primary px-6 py-20">
    <div class="mx-auto max-w-3xl">
      <p class="text-[11px] uppercase tracking-[3px] text-accent">Tools</p>
      <h1 class="mt-3 font-display text-4xl text-ink md:text-6xl">
        What I use. <span class="text-accent">Curated, not comprehensive.</span>
      </h1>
      <p class="mt-6 text-muted leading-relaxed">
        Software I rely on every day, organized by what it actually does. Most of these I install
        for clients, too, when it makes sense. Some links are affiliate, most aren't; I only
        list things I'd put on my own machine.
      </p>
      <p class="mt-3 text-xs text-muted/80">{totalTools} tools across {toolCategories.length} categories.</p>
    </div>
  </section>

  <div class="border-t border-accent/15 px-6 py-12">
    <div class="mx-auto max-w-7xl lg:grid lg:grid-cols-[220px_1fr] lg:gap-12">
      <aside class="mb-10 border-b border-accent/15 pb-8 lg:mb-0 lg:border-b-0 lg:border-r lg:border-accent/15 lg:pr-6 lg:pb-0 lg:sticky lg:top-[88px] lg:self-start lg:max-h-[calc(100vh-104px)] lg:overflow-y-auto">
        <p class="mb-4 text-[11px] uppercase tracking-[3px] text-accent">Categories</p>
        <nav class="flex flex-col items-start gap-2.5 text-xs uppercase tracking-[2px]">
          {toolCategories.map((c) => (
            <a href={`#${c.slug}`} data-cat-link={c.slug} class="text-left text-muted hover:text-accent transition">
              {c.title}
            </a>
          ))}
        </nav>
      </aside>

      <div class="space-y-16">
        {toolCategories.map((cat) => (
          <section id={cat.slug} class="cv-defer scroll-mt-24">
            <SectionHeader
              eyebrow={`${cat.tools.length} ${cat.tools.length === 1 ? "tool" : "tools"}`}
              title={cat.title}
              subtitle={cat.summary}
            />
            <div class="grid gap-4 md:grid-cols-2">
              {cat.tools.map((tool) => (
                <article class="border border-accent/15 bg-bg-card p-5 card-lift">
                  <div class="flex items-start justify-between gap-3">
                    <h3 class="font-display text-lg text-ink">
                      {tool.url ? (
                        <a href={tool.url} target="_blank" rel="noopener" class="hover:text-accent">
                          {tool.name} <span class="text-xs text-muted">↗</span>
                        </a>
                      ) : (
                        tool.name
                      )}
                    </h3>
                    <span class={`shrink-0 border px-2 py-0.5 text-[10px] uppercase tracking-wider ${pricingLabel[tool.pricing].cls}`}>
                      {pricingLabel[tool.pricing].text}
                    </span>
                  </div>
                  <p class="mt-2 text-sm text-muted leading-relaxed">{tool.blurb}</p>
                  {tool.tags && tool.tags.length > 0 && (
                    <ul class="mt-3 flex flex-wrap gap-1.5">
                      {tool.tags.map((t) => <li class="chip !text-[10px] !py-0.5">{t}</li>)}
                    </ul>
                  )}
                </article>
              ))}
            </div>
          </section>
        ))}
      </div>
    </div>
  </div>

  <section class="bg-bg-primary px-6 py-20 text-center">
    <p class="text-xs uppercase tracking-[3px] text-accent">Want help with any of these?</p>
    <h2 class="mt-3 font-display text-3xl text-ink md:text-4xl">
      I'll set them up properly.
    </h2>
    <a href="/work-with-me/apply/" class="btn-primary mt-8">Work With Me →</a>
  </section>

  <script>
    const links = document.querySelectorAll<HTMLAnchorElement>("[data-cat-link]");
    const targets = Array.from(links).map((l) => document.getElementById(l.dataset.catLink ?? ""));
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (!e.isIntersecting) return;
          links.forEach((l) =>
            l.classList.toggle("text-accent", l.dataset.catLink === e.target.id),
          );
        });
      },
      { rootMargin: "-20% 0px -70% 0px" },
    );
    targets.forEach((t) => t && io.observe(t));
  </script>
</BaseLayout>
