---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

type Iocs = { count: number; files: string[]; indicators: Record<string, string[]> };

const entries: CollectionEntry<"cti">[] = await getCollection("cti");
const withIocs = entries
  .filter((e) => !e.data.draft && e.data.iocs)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const dateFmt = new Intl.DateTimeFormat("en-US", { month: "short", day: "numeric", year: "numeric" });

interface Row {
  value: string;
  type: string;
  slug: string;
  title: string;
  date: string;
  dateIso: string;
  search: string;
}

// Normalize a defanged value so "45.9.148.99" matches "45[.]9[.]148[.]99" etc.
const norm = (s: string) =>
  s.replace(/\[\.\]|\[dot\]|\(dot\)/gi, ".").replace(/hxxp/gi, "http").toLowerCase();

const rows: Row[] = [];
const typeCounts = new Map<string, number>();
for (const e of withIocs) {
  const iocs = e.data.iocs as Iocs;
  for (const [type, values] of Object.entries(iocs.indicators)) {
    for (const value of values) {
      rows.push({
        value,
        type,
        slug: e.slug,
        title: e.data.title,
        date: dateFmt.format(e.data.publishedAt),
        dateIso: e.data.publishedAt.toISOString(),
        search: `${norm(value)} ${e.data.title.toLowerCase()}`,
      });
      typeCounts.set(type, (typeCounts.get(type) ?? 0) + 1);
    }
  }
}

const types = [...typeCounts.entries()].sort((a, b) => b[1] - a[1]);
const totalIndicators = rows.length;
const reportCount = withIocs.length;

const title = "Indicator Database";
const description = `Searchable database of ${totalIndicators} indicators of compromise auto-extracted from ${reportCount} Bulwark Black threat reports. Search IPs, domains, URLs, hashes, and CVEs and jump to the report each came from.`;
---
<BaseLayout title={title} description={description}>
  <section class="border-b border-line bg-bg-secondary px-6 py-12 md:py-16">
    <div class="mx-auto max-w-6xl">
      <p class="eyebrow-intel">Threat Intelligence</p>
      <h1 class="mt-3 font-display text-3xl uppercase tracking-[0.02em] text-ink md:text-5xl">Indicator Database</h1>
      <p class="mt-4 max-w-2xl leading-relaxed text-muted">
        Every indicator we auto-extract from our threat reports, in one place. Search by value or report,
        filter by type, and jump straight to the article it came from. Values are defanged for safe viewing.
        Live values and YARA rules are on each report.
      </p>
      <p class="mt-4 font-mono text-xs uppercase tracking-wider text-muted">
        <span class="text-accent">{totalIndicators}</span> indicators · <span class="text-accent">{reportCount}</span> reports
      </p>
    </div>
  </section>

  <section class="px-6 py-8 md:py-10">
    <div class="mx-auto max-w-6xl">
      <input
        id="ioc-search"
        type="search"
        placeholder="Search indicators or reports (e.g. 45.9.148.99, evil-c2.net, CVE-2024, apt28)"
        autocomplete="off"
        class="block w-full border border-line bg-bg-primary px-4 py-3 font-mono text-sm text-ink placeholder:text-muted/50 focus:border-accent focus:outline-none"
      />

      <div class="mt-4 flex flex-wrap gap-2" id="ioc-types">
        <button type="button" data-type="all" class="type-chip is-active border border-line px-3 py-1.5 font-mono text-[11px] uppercase tracking-wider transition-colors">
          All ({totalIndicators})
        </button>
        {types.map(([t, n]) => (
          <button type="button" data-type={t} class="type-chip border border-line px-3 py-1.5 font-mono text-[11px] uppercase tracking-wider transition-colors">
            {t} ({n})
          </button>
        ))}
      </div>

      <p id="ioc-count" class="mt-5 font-mono text-xs text-muted">{totalIndicators} indicators</p>

      <div class="mt-3 overflow-x-auto border border-line">
        <table class="w-full min-w-[720px] border-collapse text-left">
          <thead>
            <tr class="border-b border-line bg-bg-card font-mono text-[11px] uppercase tracking-wider text-muted">
              <th class="px-4 py-3 font-normal">Indicator</th>
              <th class="px-4 py-3 font-normal">Type</th>
              <th class="px-4 py-3 font-normal">Report</th>
              <th class="whitespace-nowrap px-4 py-3 font-normal">Date</th>
            </tr>
          </thead>
          <tbody id="ioc-rows">
            {rows.map((r) => (
              <tr class="ioc-row border-b border-line/60 align-top" data-type={r.type} data-search={r.search}>
                <td class="px-4 py-2.5 font-mono text-xs text-ink/90"><span class="break-all">{r.value}</span></td>
                <td class="whitespace-nowrap px-4 py-2.5"><span class="chip">{r.type}</span></td>
                <td class="px-4 py-2.5 text-sm">
                  <a href={`/${r.slug}/`} class="text-intel transition-colors hover:text-accent">{r.title}</a>
                </td>
                <td class="whitespace-nowrap px-4 py-2.5 font-mono text-[11px] text-muted"><time datetime={r.dateIso}>{r.date}</time></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <p id="ioc-empty" class="mt-6 hidden border border-dashed border-line bg-bg-card/60 px-6 py-10 text-center text-muted">
        No indicators match your search.
      </p>

      <p class="mt-6 text-xs leading-relaxed text-muted">
        Auto-extracted from our reports and may include false positives, verify before acting. Need to pull IOCs from your own text?
        <a href="/tools/ioc-extractor/" class="text-accent hover:underline">Use the IOC Extractor →</a>
      </p>
    </div>
  </section>

  <style>
    .type-chip { color: rgb(var(--muted)); }
    .type-chip:hover { border-color: rgb(var(--accent)); color: rgb(var(--accent)); }
    .type-chip.is-active { background: rgb(var(--accent)); border-color: rgb(var(--accent)); color: #0a0e14; }
  </style>

  <script>
    const search = document.getElementById("ioc-search") as HTMLInputElement;
    const rows = Array.from(document.querySelectorAll<HTMLTableRowElement>(".ioc-row"));
    const chips = Array.from(document.querySelectorAll<HTMLButtonElement>(".type-chip"));
    const countEl = document.getElementById("ioc-count") as HTMLParagraphElement;
    const emptyEl = document.getElementById("ioc-empty") as HTMLParagraphElement;

    let activeType = "all";

    function normQuery(s: string) {
      return s.replace(/\[\.\]|\[dot\]|\(dot\)/gi, ".").replace(/hxxp/gi, "http").toLowerCase().trim();
    }

    function apply() {
      const q = normQuery(search.value);
      let shown = 0;
      for (const row of rows) {
        const typeOk = activeType === "all" || row.dataset.type === activeType;
        const searchOk = !q || (row.dataset.search ?? "").includes(q);
        const visible = typeOk && searchOk;
        row.hidden = !visible;
        if (visible) shown++;
      }
      countEl.textContent = `${shown} indicator${shown === 1 ? "" : "s"}`;
      emptyEl.classList.toggle("hidden", shown !== 0);
    }

    search.addEventListener("input", apply);
    for (const chip of chips) {
      chip.addEventListener("click", () => {
        activeType = chip.dataset.type ?? "all";
        for (const c of chips) c.classList.toggle("is-active", c === chip);
        apply();
      });
    }
  </script>
</BaseLayout>
