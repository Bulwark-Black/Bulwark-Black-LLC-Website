---
import BaseLayout from "@/layouts/BaseLayout.astro";
import JsonLd from "@/components/JsonLd.astro";
import { graph, breadcrumb } from "@/lib/jsonld";

const whoFor = [
  {
    title: "Local nonprofits",
    blurb:
      "Small teams doing real work with tight budgets, where a locked-down account or a working website makes a direct difference.",
  },
  {
    title: "Veteran-owned businesses",
    blurb:
      "Fellow veterans getting a business off the ground who need honest tech help without an enterprise price tag.",
  },
  {
    title: "First responders & small community orgs",
    blurb:
      "Volunteer fire, search and rescue, food banks, and neighborhood groups that keep the community running.",
  },
];

const whatWeOffer = [
  {
    title: "Discounted or pro-bono tech support",
    blurb:
      "Hands-on help with the day-to-day tech that keeps you running, at a reduced rate or at no cost when we can swing it.",
  },
  {
    title: "Security check-ups & audits",
    blurb:
      "A plain-language look at your accounts, devices, and backups, with a short list of the fixes that actually matter.",
  },
  {
    title: "Website & email help",
    blurb:
      "Get a simple site live, clean up a broken one, or sort out email so your messages land instead of bouncing.",
  },
  {
    title: "Guidance you can act on",
    blurb:
      "Straight answers about tools, spending, and what to do next, written for the person who has to make the call.",
  },
];
---
<BaseLayout
  title="Community Tech"
  description="Community Tech from Bulwark Black: free and discounted technology and cybersecurity help for local nonprofits, veterans, and small community organizations. Veteran-owned, rooted in rural Washington."
>
  <JsonLd slot="head" data={graph(
    breadcrumb([{ name: "Home", path: "/" }, { name: "Community", path: "/community/" }]),
  )} />

  {/* Hero */}
  <section class="grid-bg border-b border-line bg-bg-primary px-6 py-20">
    <div class="mx-auto max-w-3xl">
      <p class="eyebrow">Community</p>
      <h1 class="mt-3 font-display text-4xl uppercase tracking-[0.04em] text-ink md:text-6xl">
        Community <span class="text-accent">Tech</span>
      </h1>
      <p class="mt-6 font-display text-xl text-accent md:text-2xl">
        We give back by keeping our community secure and online.
      </p>
    </div>
  </section>

  {/* What it is */}
  <section class="border-b border-line bg-bg-secondary px-6 py-16">
    <div class="mx-auto max-w-3xl">
      <p class="eyebrow-intel">What this is</p>
      <p class="mt-4 text-lg leading-relaxed text-ink/90">
        Bulwark Black is a veteran-owned company rooted in rural Washington. Community Tech is how we
        put that to work close to home: we help local nonprofits, veterans, and small organizations
        that cannot afford real tech and security support get it anyway.
      </p>
      <p class="mt-4 leading-relaxed text-muted">
        Some of it is free, some of it is deeply discounted. The goal is the same either way, to keep
        the organizations that hold our community together secure and online.
      </p>
    </div>
  </section>

  {/* Who it's for */}
  <section class="border-b border-line bg-bg-primary px-6 py-16">
    <div class="mx-auto max-w-6xl">
      <p class="eyebrow">Who it's for</p>
      <h2 class="mt-3 font-display text-2xl uppercase tracking-[0.02em] text-ink md:text-3xl">
        The people we want to help
      </h2>
      <div class="accent-line mt-5"></div>
      <div class="mt-8 grid gap-4 md:grid-cols-3">
        {whoFor.map((w) => (
          <div class="border border-line bg-bg-card p-6 card-lift">
            <h3 class="font-display text-lg text-ink">{w.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{w.blurb}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* What we offer */}
  <section class="border-b border-line bg-bg-secondary px-6 py-16">
    <div class="mx-auto max-w-6xl">
      <p class="eyebrow-intel">What we offer</p>
      <h2 class="mt-3 font-display text-2xl uppercase tracking-[0.02em] text-ink md:text-3xl">
        The kind of help we bring
      </h2>
      <div class="accent-line mt-5"></div>
      <div class="mt-8 grid gap-4 md:grid-cols-2">
        {whatWeOffer.map((o) => (
          <div class="flex gap-3 border border-line bg-bg-card p-6">
            <span class="mt-1 shrink-0 font-mono text-intel" aria-hidden="true">▸</span>
            <div>
              <h3 class="font-display text-lg text-ink">{o.title}</h3>
              <p class="mt-1.5 text-sm leading-relaxed text-muted">{o.blurb}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* CTA band */}
  <section class="bg-bg-primary px-6 py-20 text-center">
    <div class="mx-auto max-w-2xl">
      <h2 class="font-display text-3xl text-ink md:text-4xl">
        Know an org that could use a hand?
      </h2>
      <p class="mx-auto mt-4 max-w-xl leading-relaxed text-muted">
        Tell us who they are and what they are up against. If we can help, we will.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/contact/" class="btn-primary">Know an org that could use a hand? →</a>
      </div>
    </div>
  </section>
</BaseLayout>
