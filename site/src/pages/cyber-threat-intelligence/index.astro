---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import JsonLd from "@/components/JsonLd.astro";
import { graph, breadcrumb } from "@/lib/jsonld";

const allEntries: CollectionEntry<"cti">[] = await getCollection("cti");
const entries = allEntries
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const capabilities = [
  {
    title: "Threat-actor tracking",
    body: "Profiles and running notes on active groups, their infrastructure, and how their targeting shifts over time.",
  },
  {
    title: "Malware & TTP analysis",
    body: "Breakdowns of malware families and attacker techniques, mapped to the behavior defenders can actually detect.",
  },
  {
    title: "IOC & YARA downloads",
    body: "Machine-readable indicators and YARA rules attached to reports, so your team can hunt and block without re-typing.",
  },
];
---
<BaseLayout
  title="Cyber Threat Intelligence"
  description="Daily cyber threat intelligence from Bulwark Black: threat-actor tracking, malware and TTP analysis, and downloadable IOC and YARA rules for defenders."
>
  <JsonLd slot="head" data={graph(
    breadcrumb([{ name: "Home", path: "/" }, { name: "Cyber Threat Intelligence", path: "/cyber-threat-intelligence/" }]),
  )} />

  <section class="grid-bg relative overflow-hidden border-b border-line bg-bg-primary px-6 py-20">
    <div class="mx-auto max-w-3xl">
      <p class="eyebrow-intel">Intel Feed</p>
      <h1 class="mt-3 font-display text-4xl uppercase tracking-[0.04em] text-ink md:text-6xl">
        Cyber Threat <span class="text-intel">Intelligence</span>
      </h1>
      <p class="mt-6 leading-relaxed text-muted">
        Daily reporting on the threats that matter, written to be used. We track active actors, pull apart malware and techniques, and publish indicators you can feed straight into your defenses.
      </p>
    </div>
  </section>

  <section class="border-b border-line bg-bg-secondary px-6 py-16">
    <div class="mx-auto grid max-w-6xl gap-5 md:grid-cols-3">
      {capabilities.map((c) => (
        <div class="border border-line bg-bg-card p-6">
          <h2 class="font-display text-lg text-ink">{c.title}</h2>
          <p class="mt-2 text-sm leading-relaxed text-muted">{c.body}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-bg-primary px-6 py-20">
    <div class="mx-auto max-w-6xl">
      <SectionHeader eyebrow="Reports" title="Latest reporting" />

      {entries.length > 0 ? (
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {entries.map((entry, i) => (
            <ArticleCard entry={entry} loading={i < 6 ? "eager" : "lazy"} />
          ))}
        </div>
      ) : (
        <div class="border border-dashed border-line bg-bg-card/60 px-6 py-16 text-center">
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-intel">Archive migration in progress</p>
          <p class="mt-4 font-display text-2xl text-ink">Latest intelligence, landing soon.</p>
          <p class="mx-auto mt-3 max-w-lg text-sm leading-relaxed text-muted">
            We are migrating roughly 390 cyber threat intelligence articles into the new site. New daily reporting and the full archive will appear here shortly. Want it in your inbox as it lands? Subscribe to the brief on any page.
          </p>
          <a href="/contact/" class="mt-6 inline-flex btn-outline !py-2 !text-xs">Ask about custom intel →</a>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
