---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import { site } from "@/lib/site";
---
<BaseLayout title="Application Received" description="Thanks for reaching out, here's what happens next." noindex>
  <section class="grid-bg bg-bg-primary px-6 py-24">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-[11px] uppercase tracking-[3px] text-accent">★ Received</p>
      <h1 class="mt-4 font-display text-4xl text-ink md:text-6xl">
        Got it. <span class="text-accent">Talk soon.</span>
      </h1>
      <p class="mx-auto mt-6 max-w-xl text-muted leading-relaxed">
        Your application is on the way. I read every one personally and reply within one business
        day, usually faster.
      </p>
      <p class="mx-auto mt-3 max-w-xl text-xs text-muted/80">
        Didn't see your email client open? Send it the old way:
        <a href="mailto:support@bulwarkblack.com" class="text-accent">support@bulwarkblack.com</a>
      </p>
    </div>
  </section>

  <section class="bg-bg-secondary px-6 py-20">
    <div class="mx-auto max-w-3xl">
      <div class="border border-accent/30 bg-bg-card p-8 md:p-10">
        <p class="text-[11px] uppercase tracking-[3px] text-accent">Want to skip the queue?</p>
        <h2 class="mt-3 font-display text-3xl text-ink md:text-4xl">
          Book a call instead.
        </h2>
        <p class="mt-4 text-muted leading-relaxed">
          A paid {site.booking.duration} call with me, on the calendar this week if I have an
          open slot. Bring the same situation you just wrote up and we'll talk through it live.
          Sometimes that's the fastest path to a real answer.
        </p>
        <div class="mt-6 flex flex-wrap items-baseline gap-x-4 gap-y-1">
          <p class="font-display text-3xl text-ink">{site.booking.price}</p>
          <p class="text-sm text-muted">{site.booking.duration}, one-on-one</p>
        </div>
        <p class="mt-1 text-xs text-muted">{site.booking.priceNote}</p>
        <a href={site.booking.calendlyUrl} class="btn-primary mt-6" rel="noopener" target="_blank">
          Book Your Call →
        </a>
        <p class="mt-4 text-xs text-muted/80">
          Prefer to wait for my email reply? Totally fine, no pressure.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-bg-primary px-6 py-20">
    <div class="mx-auto max-w-4xl">
      <SectionHeader eyebrow="While You're Here" title="Three things worth reading." />
      <div class="grid gap-4 md:grid-cols-3">
        <a href="/how-i-work/" class="block border border-accent/15 bg-bg-card p-6 card-lift">
          <p class="text-xs uppercase tracking-[2px] text-accent">Method</p>
          <p class="mt-2 font-display text-lg text-ink">How I Work</p>
          <p class="mt-2 text-sm text-muted">Four steps. Fundamentals first. Documentation always.</p>
          <span class="mt-4 inline-block text-xs uppercase tracking-wider text-accent">Open →</span>
        </a>
        <a href="/services/" class="block border border-accent/15 bg-bg-card p-6 card-lift">
          <p class="text-xs uppercase tracking-[2px] text-accent">Scope</p>
          <p class="mt-2 font-display text-lg text-ink">What I Help With</p>
          <p class="mt-2 text-sm text-muted">Personal IT, websites + AI, automation, and small-business cybersecurity.</p>
          <span class="mt-4 inline-block text-xs uppercase tracking-wider text-accent">Open →</span>
        </a>
        <a href="/tools/" class="block border border-accent/15 bg-bg-card p-6 card-lift">
          <p class="text-xs uppercase tracking-[2px] text-accent">Stack</p>
          <p class="mt-2 font-display text-lg text-ink">Tools I Use</p>
          <p class="mt-2 text-sm text-muted">The software I rely on every day, and install for clients.</p>
          <span class="mt-4 inline-block text-xs uppercase tracking-wider text-accent">Open →</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
