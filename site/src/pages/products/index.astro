---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SoftwareCard from "@/components/SoftwareCard.astro";
import JsonLd from "@/components/JsonLd.astro";
import { graph, breadcrumb, softwareApplication } from "@/lib/jsonld";

const APP_STORE_URL = "https://apps.apple.com/us/app/va-disability-calc-track/id6748180691";

const jsonldApps = [
  softwareApplication({
    name: "Contractor Codex",
    description:
      "A branded client portal that lets contractors send a quote in 60 seconds, get it accepted and signed online, and auto-invoice the deposit and every stage as the work gets done.",
    url: "https://contractorcodex.com",
    appCategory: "BusinessApplication",
    operatingSystem: "Web",
  }),
  softwareApplication({
    name: "SAMscout AI",
    description:
      "An AI federal-proposal platform that turns a SAM.gov opportunity into a reviewable, Shipley-grade draft in minutes, with live opportunity intelligence, FAR/DFARS compliance, and price-to-win pricing.",
    url: "https://samscout.ai",
    appCategory: "BusinessApplication",
    operatingSystem: "Web",
  }),
  softwareApplication({
    name: "VA Disability Calc & Track",
    description:
      "The most comprehensive VA disability calculator: BVA-accurate combined-rating math, payment estimates, and claim-tracking tools, all running privately on your device.",
    url: APP_STORE_URL,
    appCategory: "UtilitiesApplication",
    operatingSystem: "iOS",
  }),
];

const vaStats = [
  "BVA-accurate combined-rating math",
  "900+ diagnostic codes + 38 CFR",
  "Encrypted Document Vault (AES-256-GCM + Face ID)",
  "100% offline",
];
---
<BaseLayout
  title="Software"
  description="Software from Bulwark Black: Contractor Codex, a client portal that quotes, contracts, and bills; SAMscout AI, an AI federal-proposal platform; and VA Disability Calc & Track for iOS. Live in production and the App Store."
>
  <JsonLd slot="head" data={graph(
    breadcrumb([{ name: "Home", path: "/" }, { name: "Software", path: "/products/" }]),
    ...jsonldApps,
  )} />

  {/* Hero */}
  <section class="grid-bg border-b border-line bg-bg-primary px-6 py-20">
    <div class="mx-auto max-w-3xl">
      <p class="eyebrow">Software · Built &amp; Live</p>
      <h1 class="mt-3 font-display text-4xl uppercase tracking-[0.04em] text-ink md:text-6xl">
        Our <span class="text-accent">Software</span>
      </h1>
      <p class="mt-6 leading-relaxed text-muted">
        Two SaaS platforms and an iOS app we build, run, and pay the bills with, live in production
        and the App Store, not concepts.
      </p>
    </div>
  </section>

  {/* SaaS co-headliners */}
  <section class="border-b border-line bg-bg-secondary px-6 py-20">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-6 md:grid-cols-2">
        <SoftwareCard
          name="Contractor Codex"
          chip="SaaS · Web app"
          tagline="Quote. Contract. Bill. Get Paid."
          oneLiner="A branded client portal that lets contractors send a quote in 60 seconds, get it accepted and signed online, and auto-invoice the deposit and every stage as the work gets done."
          features={[
            "60-second AI-drafted quotes from a 240-item library across 25 industries",
            "Auto-invoicing on acceptance with five billing modes (deposit, full, on completion, and progress stages)",
            "Built-in contracts + e-signatures with audit trail and optional DocuSign sync",
            "Stripe pay-now links plus the Codex suite — per-project profit tracking and an AI business advisor",
          ]}
          pricing="Standard $15/mo · Pro $35/mo · unlimited clients · free trial"
          href="https://contractorcodex.com"
          ctaLabel="Start Your Free Trial →"
          external={true}
          secondaryHref="https://contractorcodex.com"
          secondaryLabel="See all features →"
          titleHref="https://contractorcodex.com"
          accent={true}
        />
        <SoftwareCard
          name="SAMscout AI"
          chip="SaaS · Web app"
          tagline="The federal proposal team you can afford to hire."
          oneLiner="An AI federal-proposal platform that turns a SAM.gov opportunity into a reviewable, Shipley-grade draft in minutes — with live opportunity intelligence, FAR/DFARS compliance, and price-to-win pricing running in parallel."
          features={[
            "AI contract intelligence that extracts scope, requirements, criteria, and key dates (auto-refreshed on amendments)",
            "Draft Studio — a 22-agent Shipley-methodology proposal generator with Section-Gate quality control",
            "FAR/DFARS compliance gate that checks clauses, page limits, and set-aside rules before any AI writes",
            "Price-to-win pricing from BLS labor rates + GSA CALC+ ceilings, with an AI pricing narrative",
          ]}
          pricing="Free Recruit tier · Vanguard $29.99/mo · Elite $39.99/mo (Most Popular) · bring your own AI key"
          href="https://app.samscout.ai"
          ctaLabel="Start Free →"
          external={true}
          secondaryHref="https://samscout.ai"
          secondaryLabel="See all features →"
          titleHref="https://samscout.ai"
          accent={true}
        />
      </div>
    </div>
  </section>

  {/* VA app, third */}
  <section class="border-b border-line bg-bg-primary px-6 py-20">
    <div class="mx-auto max-w-6xl">
      <article class="grid gap-10 border border-line bg-bg-card p-8 md:grid-cols-[1.1fr_1fr] md:p-12">
        <div class="flex flex-col">
          <div class="flex items-start justify-between gap-3">
            <h2 class="font-display text-2xl font-semibold text-ink md:text-3xl">
              VA Disability Calc &amp; Track
            </h2>
            <span class="shrink-0 border border-intel/30 px-2 py-0.5 font-mono text-[10px] uppercase tracking-wider text-intel">
              iOS · iPhone &amp; iPad
            </span>
          </div>
          <p class="mt-3 font-display text-lg text-accent">Know your rating. Track your claim.</p>
          <p class="mt-3 text-sm leading-relaxed text-muted">
            The most comprehensive VA disability calculator — BVA-accurate combined-rating math,
            payment estimates, and claim-tracking tools, all running privately on your device.
          </p>
          <div class="mt-auto pt-8">
            <div class="flex flex-wrap items-center gap-3">
              <a href={APP_STORE_URL} target="_blank" rel="noopener" class="btn-primary">
                Download Free on the App Store →
              </a>
              <a href="/va-disability-calc-track-app/" class="btn-outline">See the app details →</a>
            </div>
            <a
              href="/va-disability-calc-track/"
              class="mt-4 inline-block font-mono text-[11px] text-muted underline hover:text-accent"
            >
              Privacy policy →
            </a>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          {vaStats.map((s) => (
            <div class="flex items-center border border-line bg-bg-secondary p-5">
              <p class="text-sm font-semibold leading-snug text-ink">{s}</p>
            </div>
          ))}
        </div>
      </article>
    </div>
  </section>

  {/* Custom-build bridge */}
  <section class="bg-bg-primary px-6 py-20">
    <div class="mx-auto max-w-6xl">
      <div class="border border-line bg-bg-card p-8 text-center">
        <h2 class="font-display text-2xl text-ink">Have an app idea for your business?</h2>
        <p class="mx-auto mt-3 max-w-xl text-sm leading-relaxed text-muted">
          Web or iOS, from a focused first version to a full product. Tell us the outcome you want
          and we will tell you the shortest path to it.
        </p>
        <div class="mt-6 flex flex-wrap justify-center gap-4">
          <a href="/contact/" class="btn-primary">Start a conversation →</a>
          <a href="/services/" class="btn-ghost">See services →</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
