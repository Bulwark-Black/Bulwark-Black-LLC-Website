---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import JsonLd from "@/components/JsonLd.astro";
import { graph, breadcrumb, softwareApplication } from "@/lib/jsonld";

const flagship = {
  name: "VA Disability Calc & Track",
  platform: "iOS · iPhone & iPad",
  url: "https://apps.apple.com/us/app/va-disability-calc-track/id6748180691",
  description:
    "A native app for veterans navigating VA claims. BVA-accurate combined-rating math, 900+ diagnostic codes, an encrypted document vault, and full offline operation.",
  stats: [
    { k: "Diagnostic codes", v: "900+" },
    { k: "Combined-rating math", v: "BVA-accurate" },
    { k: "Document vault", v: "Encrypted" },
    { k: "Works offline", v: "100%" },
  ],
};

const products = [
  {
    name: "SAMscout.ai",
    platform: "Web",
    url: "https://samscout.ai",
    description: "Multi-agent AI platform that drafts federal contracting proposals.",
  },
  {
    name: "Contractor Codex",
    platform: "Web",
    url: "https://contractorcodex.com",
    description:
      "Branded client portal for service businesses: time tracking, invoicing, Stripe payments, and client approval workflows.",
  },
];

const jsonldApps = [
  softwareApplication({
    name: flagship.name,
    description: flagship.description,
    url: flagship.url,
    appCategory: "UtilitiesApplication",
    operatingSystem: "iOS",
  }),
  ...products.map((p) =>
    softwareApplication({ name: p.name, description: p.description, url: p.url, appCategory: "BusinessApplication" }),
  ),
];
---
<BaseLayout
  title="Apps & Products"
  description="Apps and products built by Bulwark Black, including VA Disability Calc & Track for iOS, SAMscout.ai, and Contractor Codex. Custom web and iOS apps built for businesses."
>
  <JsonLd slot="head" data={graph(
    breadcrumb([{ name: "Home", path: "/" }, { name: "Apps", path: "/products/" }]),
    ...jsonldApps,
  )} />

  <section class="grid-bg border-b border-line bg-bg-primary px-6 py-20">
    <div class="mx-auto max-w-3xl">
      <p class="eyebrow">Apps &amp; Products</p>
      <h1 class="mt-3 font-display text-4xl uppercase tracking-[0.04em] text-ink md:text-6xl">
        Software we <span class="text-accent">shipped</span>
      </h1>
      <p class="mt-6 leading-relaxed text-muted">
        We build custom web and iOS apps for businesses and ship our own products too. These are live, in the App Store and in production, not concepts. The same team that built these can build yours.
      </p>
      <div class="mt-8">
        <a href="/contact/" class="btn-primary">Build your app with us →</a>
      </div>
    </div>
  </section>

  <!-- Flagship -->
  <section class="border-b border-line bg-bg-secondary px-6 py-20">
    <div class="mx-auto max-w-6xl">
      <div class="grid items-center gap-10 border border-line bg-bg-card p-8 md:grid-cols-[1.1fr_1fr] md:p-12">
        <div>
          <p class="eyebrow">Flagship · {flagship.platform}</p>
          <h2 class="mt-4 font-display text-3xl text-ink md:text-4xl">{flagship.name}</h2>
          <p class="mt-4 leading-relaxed text-muted">{flagship.description}</p>
          <div class="mt-8 flex flex-wrap items-center gap-4">
            <a href={flagship.url} class="btn-primary" rel="noopener" target="_blank">View on the App Store →</a>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          {flagship.stats.map((s) => (
            <div class="border border-line bg-bg-secondary p-5">
              <p class="font-display text-xl text-accent">{s.v}</p>
              <p class="mt-1 font-mono text-[11px] uppercase tracking-wider text-muted">{s.k}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Other products -->
  <section class="bg-bg-primary px-6 py-20">
    <div class="mx-auto max-w-6xl">
      <SectionHeader eyebrow="Also shipped" title="More from the workbench" />
      <div class="grid gap-5 md:grid-cols-2">
        {products.map((p) => (
          <a href={p.url} rel="noopener" target="_blank" class="group flex flex-col border border-line bg-bg-card p-7 card-lift">
            <div class="flex items-center justify-between gap-3">
              <h3 class="font-display text-xl text-ink group-hover:text-accent">{p.name}</h3>
              <span class="chip shrink-0">{p.platform}</span>
            </div>
            <p class="mt-2 text-sm leading-relaxed text-muted">{p.description}</p>
            <span class="mt-4 font-mono text-[11px] uppercase tracking-wider text-accent">Visit →</span>
          </a>
        ))}
      </div>

      <div class="mt-12 border border-line bg-bg-card p-8 text-center">
        <h2 class="font-display text-2xl text-ink">Have an app idea for your business?</h2>
        <p class="mx-auto mt-3 max-w-xl text-sm leading-relaxed text-muted">
          Web or iOS, from a focused first version to a full product. Tell us the outcome you want and we will tell you the shortest path to it.
        </p>
        <div class="mt-6 flex flex-wrap justify-center gap-4">
          <a href="/contact/" class="btn-primary">Start a conversation →</a>
          <a href="/services/" class="btn-ghost">See services →</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
