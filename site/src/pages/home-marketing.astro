---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import JsonLd from "@/components/JsonLd.astro";
import { graph, softwareApplication } from "@/lib/jsonld";

import Hero from "@/components/landing/Hero.astro";
import StatsBar from "@/components/landing/StatsBar.astro";
import FeaturesGrid from "@/components/landing/FeaturesGrid.astro";
import IntelFeed from "@/components/landing/IntelFeed.astro";
import WhyBulwark from "@/components/landing/WhyBulwark.astro";
import HowItWorks from "@/components/landing/HowItWorks.astro";
import FlagshipApp from "@/components/landing/FlagshipApp.astro";
import FinalCta from "@/components/landing/FinalCta.astro";

import "@/styles/landing.css";

// Three most-recent published CTI reports for the "Inside the Intel Feed" section.
const allCti: CollectionEntry<"cti">[] = await getCollection("cti");
const dateFmt = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
});
const feedEntries = allCti
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3)
  .map((entry) => ({
    href: `/${entry.slug}/`,
    category: entry.data.category ?? "Intel",
    date: dateFmt.format(entry.data.publishedAt),
    title: entry.data.title,
    summary: entry.data.summary,
  }));

const flagshipApp = softwareApplication({
  name: "VA Disability Calc & Track",
  description:
    "iOS app for veterans navigating VA claims. BVA-accurate combined-rating math, 900+ diagnostic codes, an encrypted document vault, and fully offline operation.",
  url: "https://apps.apple.com/us/app/va-disability-calc-track/id6748180691",
  appCategory: "UtilitiesApplication",
  operatingSystem: "iOS",
});
---
<BaseLayout
  title="Cyber Threat Intelligence, Custom Software & Remote Tech Help"
  description="Bulwark Black is a veteran-owned (SDVOSB) studio. Daily cyber threat intelligence plus custom web and iOS apps, AI setup, and small-business IT and cybersecurity, delivered remotely across the US."
>
  <JsonLd slot="head" data={graph(flagshipApp)} />

  <div class="bb-landing">
    <Hero />
    <StatsBar />
    <FeaturesGrid />
    <IntelFeed entries={feedEntries} />
    <WhyBulwark />
    <HowItWorks />
    <FlagshipApp />
    <FinalCta />
  </div>
</BaseLayout>

<script is:inline>
  // Scroll-reveal: fade elements up as they enter view. Scoped to the landing.
  (function () {
    if (typeof window === "undefined") return;
    var els = document.querySelectorAll(".bb-landing .reveal");
    if (!els.length) return;
    if (
      window.matchMedia &&
      window.matchMedia("(prefers-reduced-motion: reduce)").matches
    ) {
      els.forEach(function (el) {
        el.classList.add("is-visible");
      });
      return;
    }
    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: "0px 0px -60px 0px" }
    );
    els.forEach(function (el) {
      observer.observe(el);
    });
  })();
</script>
