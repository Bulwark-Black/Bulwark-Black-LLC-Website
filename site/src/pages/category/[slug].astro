---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import JsonLd from "@/components/JsonLd.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { graph, breadcrumb } from "@/lib/jsonld";
import { wpCategories, type WpCategory } from "@/lib/wp-categories";

// One archive page per WordPress category (count > 0). URLs keep the original
// category slugs so the site nav resolves — e.g. /category/russian-cyber-threat-intelligence/.
// Articles are matched by DISPLAY NAME against each cti entry's categories/category.
export async function getStaticPaths() {
  const allEntries: CollectionEntry<"cti">[] = await getCollection("cti");
  const entries = allEntries.filter((e) => !e.data.draft);
  return wpCategories.map((cat) => {
    const matched = entries
      .filter((e) => e.data.categories?.includes(cat.name) || e.data.category === cat.name)
      .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
    return { params: { slug: cat.slug }, props: { cat, matched } };
  });
}

interface Props {
  cat: WpCategory;
  matched: CollectionEntry<"cti">[];
}
const { cat, matched } = Astro.props;
const count = matched.length;

// One-line orientation for the marquee categories; generic fallback otherwise.
const DESCRIPTIONS: Record<string, string> = {
  "russian-cyber-threat-intelligence":
    "Russian state-sponsored and criminal cyber operations — the actors, malware, and infrastructure we track, and how their targeting shifts.",
  "chinese-cyber-threat-intelligence":
    "Chinese APT activity and espionage tooling — group tracking, malware and TTP analysis, and the indicators defenders can act on.",
  "north-korean-cyber-threat-intelligence":
    "North Korean threat activity, from financially motivated intrusions to espionage — actors, tooling, and the money trail behind them.",
  "iranian-cyber-threat-intelligence":
    "Iranian state and proxy cyber operations — hacktivist fronts, wipers, and ICS-focused activity, mapped to detectable behavior.",
  "anomalous-cyber-threat-intelligence":
    "Global and cross-region threat intelligence that doesn't sit under a single nation-state — emerging actors, campaigns, and anomalies.",
  malware:
    "Malware family breakdowns and reversing notes, mapped to the behavior defenders can actually detect and block.",
  detection:
    "Detection engineering — YARA, Sigma, and hunt logic turned from raw intelligence into rules you can deploy.",
  "red-teaming":
    "Offensive operations and adversary simulation — tradecraft, tooling, and the techniques red teams use in the field.",
  "bug-bounty":
    "Bug bounty and vulnerability research — write-ups, methodology, and findings from real-world testing.",
};
const description = DESCRIPTIONS[cat.slug] ?? `Bulwark Black cyber threat intelligence filed under ${cat.name}.`;
const metaDescription = `${cat.name}: ${count} report${count === 1 ? "" : "s"} from Bulwark Black. ${description}`;
---
<BaseLayout title={cat.name} description={metaDescription}>
  <JsonLd slot="head" data={graph(
    breadcrumb([
      { name: "Home", path: "/" },
      { name: "Cyber Threat Intelligence", path: "/cyber-threat-intelligence/" },
      { name: cat.name, path: `/category/${cat.slug}/` },
    ]),
  )} />

  <section class="grid-bg relative overflow-hidden border-b border-line bg-bg-primary px-6 py-16 md:py-20">
    <div class="mx-auto max-w-3xl">
      <p class="eyebrow-intel">Category Archive</p>
      <h1 class="mt-3 font-display text-4xl uppercase tracking-[0.03em] text-ink md:text-5xl">{cat.name}</h1>
      <p class="mt-4 flex flex-wrap items-center gap-3 font-mono text-[11px] uppercase tracking-wider">
        <span class="text-accent">{count} report{count === 1 ? "" : "s"}</span>
        <span class="text-muted/40">·</span>
        <a href="/cyber-threat-intelligence/" class="text-muted hover:text-accent">All intelligence</a>
      </p>
      <p class="mt-5 max-w-2xl leading-relaxed text-muted">{description}</p>
    </div>
  </section>

  <section class="bg-bg-primary px-6 py-14 md:py-16">
    <div class="mx-auto max-w-7xl">
      {count > 0 ? (
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {matched.map((entry, i) => (
            <ArticleCard entry={entry} loading={i < 6 ? "eager" : "lazy"} />
          ))}
        </div>
      ) : (
        <div class="border border-dashed border-line bg-bg-card/60 px-6 py-16 text-center">
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-intel">No reports yet</p>
          <p class="mt-4 font-display text-2xl text-ink">Nothing filed under {cat.name} yet.</p>
          <p class="mx-auto mt-3 max-w-lg text-sm leading-relaxed text-muted">
            New reporting lands here as it publishes. In the meantime, browse the full threat intel feed.
          </p>
          <a href="/cyber-threat-intelligence/" class="mt-6 inline-flex btn-outline !py-2 !text-xs">Open the intel feed →</a>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
