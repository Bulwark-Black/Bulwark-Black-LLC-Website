---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import JsonLd from "@/components/JsonLd.astro";
import { graph, breadcrumb } from "@/lib/jsonld";
---
<BaseLayout title="Work With Me" description="What working together looks like and how to apply.">
  <JsonLd slot="head" data={graph(
    breadcrumb([{ name: "Home", path: "/" }, { name: "Work With Me", path: "/work-with-me/" }]),
  )} />
  <section class="grid-bg bg-bg-primary px-6 py-20">
    <div class="mx-auto max-w-3xl">
      <p class="text-[11px] uppercase tracking-[3px] text-accent">Work With Me</p>
      <h1 class="mt-3 font-display text-4xl text-ink md:text-6xl">
        I take a small number of jobs <span class="text-accent">and finish them well.</span>
      </h1>
      <p class="mt-6 text-muted leading-relaxed">
        I'd rather do five jobs right than fifty jobs halfway. If you'd like me to help, fill out
        the short application, it tells me what I need to know to give you a real answer in a
        single email instead of three.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="/work-with-me/apply/" class="btn-primary">Work With Me →</a>
        <a href="/services/" class="btn-ghost">See what I help with</a>
      </div>
    </div>
  </section>

  <section class="bg-bg-secondary px-6 py-20">
    <div class="mx-auto max-w-5xl">
      <SectionHeader eyebrow="The Short Version" title="Here's how it goes." />
      <ol class="grid gap-4 md:grid-cols-3">
        <li class="border border-accent/15 bg-bg-card p-6">
          <p class="font-display text-3xl text-accent">01</p>
          <p class="mt-1 font-display text-xl text-ink">You apply</p>
          <p class="mt-3 text-sm text-muted leading-relaxed">A short form. Five minutes. Tells me what's going on and what you'd like to be different.</p>
        </li>
        <li class="border border-accent/15 bg-bg-card p-6">
          <p class="font-display text-3xl text-accent">02</p>
          <p class="mt-1 font-display text-xl text-ink">I reply</p>
          <p class="mt-3 text-sm text-muted leading-relaxed">Within one business day. Either I can help and here's what it looks like, or I can't and here's who can.</p>
        </li>
        <li class="border border-accent/15 bg-bg-card p-6">
          <p class="font-display text-3xl text-accent">03</p>
          <p class="mt-1 font-display text-xl text-ink">We start</p>
          <p class="mt-3 text-sm text-muted leading-relaxed">A short call to confirm scope, then we get to work. You get written runbooks for everything I touch.</p>
        </li>
      </ol>
    </div>
  </section>

  <section class="bg-bg-primary px-6 py-20">
    <div class="mx-auto grid max-w-5xl gap-10 md:grid-cols-2">
      <div>
        <SectionHeader eyebrow="This is for you if" title="✓ Good fit" />
        <ul class="space-y-2 text-muted">
          <li>· You want a real human who answers the phone.</li>
          <li>· You'd rather have something done right than fast.</li>
          <li>· You want to understand what I did and why.</li>
          <li>· You value documentation and being able to take it with you.</li>
          <li>· You're a household, small operator, or rural-focused team.</li>
        </ul>
      </div>
      <div>
        <SectionHeader eyebrow="This is not for you if" title="✕ Not a fit" />
        <ul class="space-y-2 text-muted">
          <li>· You need 24/7 enterprise on-call response.</li>
          <li>· You want to outsource ownership entirely and never look at it again.</li>
          <li>· You're shopping price-only, lowest-bid, and won't read the runbook.</li>
          <li>· You need someone to chase a trend, not solve a problem.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-bg-secondary px-6 py-20 text-center">
    <p class="text-xs uppercase tracking-[3px] text-accent">Ready?</p>
    <h2 class="mt-3 font-display text-3xl text-ink md:text-4xl">
      Apply to work together.
    </h2>
    <a href="/work-with-me/apply/" class="btn-primary mt-8">Work With Me →</a>
  </section>
</BaseLayout>
