---
import BaseLayout from "@/layouts/BaseLayout.astro";
import JsonLd from "@/components/JsonLd.astro";
import { site } from "@/lib/site";
import { graph, breadcrumb } from "@/lib/jsonld";
---
<BaseLayout title="Contact" description="Get in touch with Bulwark Black for cyber threat intelligence, custom web and iOS apps, AI setup, and small-business IT and cybersecurity. Remote across the US, one business day response.">
  <JsonLd slot="head" data={graph(
    breadcrumb([{ name: "Home", path: "/" }, { name: "Contact", path: "/contact/" }]),
  )} />
  <section class="grid-bg bg-bg-primary px-6 py-20">
    <div class="mx-auto max-w-3xl">
      <p class="text-[11px] uppercase tracking-[3px] text-accent">Contact</p>
      <h1 class="mt-3 font-display text-4xl text-ink md:text-6xl">
        Let's talk. <span class="text-accent">Briefly.</span>
      </h1>
      <p class="mt-6 text-muted leading-relaxed">
        Tell me what you need. I'll respond within one business day. If it's not a fit, I'll say
        so and point you toward someone who can help. Work is delivered remotely, so wherever you
        are in the US, we can get started.
      </p>
    </div>
  </section>

  <section class="bg-bg-secondary px-6 py-20">
    <div class="mx-auto grid max-w-5xl gap-10 md:grid-cols-[1fr_2fr]">
      <aside class="space-y-4 text-sm text-muted">
        <p><a class="text-accent" href={`mailto:${site.email}`}>{site.email}</a></p>
        <p>
          Registered in {site.operating.city}, {site.operating.state}<br/>
          Remote · Nationwide (US)
        </p>
        <p class="text-xs">
          Registered office: {site.address.street}, {site.address.city}, {site.address.state} {site.address.zip}
        </p>
        <p class="text-xs">Veteran-Owned · SDVOSB</p>
      </aside>
      <form class="space-y-4" data-contact-form>
        <label class="block">
          <span class="text-xs uppercase tracking-[2px] text-accent">Name *</span>
          <input required name="name" class="mt-1 w-full border border-accent/20 bg-field/50 px-3 py-2 text-ink focus:border-accent outline-none" />
        </label>
        <label class="block">
          <span class="text-xs uppercase tracking-[2px] text-accent">Email *</span>
          <input required type="email" name="email" class="mt-1 w-full border border-accent/20 bg-field/50 px-3 py-2 text-ink focus:border-accent outline-none" />
        </label>
        <label class="block">
          <span class="text-xs uppercase tracking-[2px] text-accent">Organization (if any)</span>
          <input name="organization" class="mt-1 w-full border border-accent/20 bg-field/50 px-3 py-2 text-ink focus:border-accent outline-none" />
        </label>
        <label class="block">
          <span class="text-xs uppercase tracking-[2px] text-accent">What's going on? *</span>
          <textarea required name="message" rows="6" placeholder="A sentence or two is plenty." class="mt-1 w-full border border-accent/20 bg-field/50 px-3 py-2 text-ink focus:border-accent outline-none"></textarea>
        </label>
        <input type="text" name="website" tabindex="-1" autocomplete="off" class="absolute -left-[9999px] h-0 w-0 opacity-0" aria-hidden="true" />
        <button type="submit" data-contact-submit class="btn-primary">Send →</button>
        <p data-contact-result class="text-sm" hidden></p>
      </form>
    </div>
  </section>

  <script>
    const form = document.querySelector<HTMLFormElement>("[data-contact-form]");
    const submit = document.querySelector<HTMLButtonElement>("[data-contact-submit]");
    const out = document.querySelector<HTMLParagraphElement>("[data-contact-result]");

    function setResult(msg: string, ok: boolean) {
      if (!out) return;
      out.hidden = false;
      out.textContent = msg;
      out.className = `text-sm ${ok ? "text-accent" : "text-rose-400"}`;
    }

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!submit) return;
      const fd = new FormData(form);
      const payload = {
        name: String(fd.get("name") ?? "").trim(),
        email: String(fd.get("email") ?? "").trim(),
        organization: String(fd.get("organization") ?? "").trim(),
        message: String(fd.get("message") ?? "").trim(),
        website: String(fd.get("website") ?? "").trim(),
      };

      submit.disabled = true;
      submit.textContent = "Sending…";
      setResult("", true);

      try {
        const res = await fetch("/api/contact", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(payload),
        });
        if (!res.ok) {
          const data = await res.json().catch(() => ({ error: "submission failed" }));
          throw new Error(data.error || "submission failed");
        }
        setResult("Message sent. Redirecting…", true);
        setTimeout(() => { window.location.href = "/confirmed/"; }, 800);
      } catch (err) {
        setResult(`Couldn't send: ${(err as Error).message}. Try again, or email support@bulwarkblack.com.`, false);
        submit.disabled = false;
        submit.textContent = "Send →";
      }
    });
  </script>
</BaseLayout>
