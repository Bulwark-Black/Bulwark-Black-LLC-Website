---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import JsonLd from "@/components/JsonLd.astro";
import ArticleCard from "@/components/ArticleCard.astro";
import SoftwareCard from "@/components/SoftwareCard.astro";
import ThreatSpotlight from "@/components/ThreatSpotlight.astro";
import NewsletterForm from "@/components/NewsletterForm.astro";
import { serviceCategories } from "@/lib/services";
import { wpCategories } from "@/lib/wp-categories";
import { graph, softwareApplication } from "@/lib/jsonld";

// Newest first, published only. The article wall IS the homepage.
const allEntries: CollectionEntry<"cti">[] = await getCollection("cti");
const all = allEntries
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const lead = all[0];
const beside = all.slice(1, 5); // rail beside the lead
const grid = all.slice(5, 13); // rotating "This Week in Threats" spotlight
const missed = all.slice(20, 24); // "you may have missed"

// Display name -> archive slug, from the WordPress category export.
const slugByName = new Map(wpCategories.map((c) => [c.name, c.slug]));

// Distinct categories with counts, most-used first, for the browse band.
const catCount = new Map<string, number>();
for (const entry of all) {
  const c = entry.data.category?.trim();
  if (c) catCount.set(c, (catCount.get(c) ?? 0) + 1);
}
const categories = [...catCount.entries()]
  .map(([name, count]) => ({ name, count, slug: slugByName.get(name) }))
  .sort((a, b) => b.count - a.count);

// Intelligence-by-region blocks: the four nation-state tracks, each with its
// three most-recent reports. Rendered only when a region has coverage.
const REGIONS = [
  { label: "Russian Threat Intelligence", name: "Russian Cyber Threat Intelligence", flag: "🇷🇺", short: "Russian" },
  { label: "Chinese Threat Intelligence", name: "Chinese Cyber Threat Intelligence", flag: "🇨🇳", short: "Chinese" },
  { label: "North Korean Threat Intelligence", name: "North Korean Cyber Threat Intelligence", flag: "🇰🇵", short: "North Korean" },
  { label: "Iranian Threat Intelligence", name: "Iranian Cyber Threat Intelligence", flag: "🇮🇷", short: "Iranian" },
];
const regions = REGIONS.map((r) => ({
  ...r,
  slug: slugByName.get(r.name),
  articles: all
    .filter((e) => e.data.categories?.includes(r.name) || e.data.category === r.name)
    .slice(0, 3),
})).filter((r) => r.slug && r.articles.length > 0);

const flagshipApp = softwareApplication({
  name: "VA Disability Calc & Track",
  description:
    "iOS app for veterans navigating VA claims. BVA-accurate combined-rating math, 900+ diagnostic codes, an encrypted document vault, and fully offline operation.",
  url: "https://apps.apple.com/us/app/va-disability-calc-track/id6748180691",
  appCategory: "UtilitiesApplication",
  operatingSystem: "iOS",
});
---
<BaseLayout
  title="Cyber Threat Intelligence, Custom Software & Remote Tech Help"
  description="Daily cyber threat intelligence from Bulwark Black, a veteran-owned (SDVOSB) studio: threat-actor tracking, malware and TTP analysis, and downloadable IOCs, plus custom web and iOS apps, AI setup, and small-business IT and cybersecurity."
>
  <JsonLd slot="head" data={graph(flagshipApp)} />

  {/* a. Slim masthead strip — this is a publication, not a landing page. */}
  <section class="border-b border-line bg-bg-primary">
    <div class="mx-auto max-w-7xl px-6 py-6">
      <div class="flex flex-col gap-2 border border-line bg-bg-card p-5 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="eyebrow-intel">Cyber Threat Intelligence</p>
          <p class="mt-2 max-w-2xl text-sm leading-relaxed text-muted">
            Daily threat reporting, custom software, and remote tech help from a veteran-owned (SDVOSB) studio.
          </p>
        </div>
        <p class="shrink-0 font-mono text-[11px] uppercase tracking-wider text-muted/70">Updated most weekdays</p>
      </div>
    </div>
  </section>

  {/* a2. Our Software — lead with the apps we build and run. */}
  <section id="software" class="border-b border-line bg-bg-secondary px-6 py-14 md:py-16">
    <div class="mx-auto max-w-7xl">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="eyebrow">Our Software</p>
          <h2 class="mt-3 font-display text-3xl uppercase tracking-[0.02em] text-ink md:text-4xl">
            Software we build and run
          </h2>
        </div>
        <a
          href="/products/"
          class="font-mono text-xs uppercase tracking-wider text-accent transition-colors hover:text-accent-bright"
        >
          Explore all software →
        </a>
      </div>

      <div class="mt-8 grid gap-5 md:grid-cols-3">
        <SoftwareCard
          variant="compact"
          name="Contractor Codex"
          chip="SaaS · Web app"
          tagline="Quote. Contract. Bill. Get Paid."
          oneLiner="Send a quote in 60 seconds, get it signed online, and auto-invoice every stage of the job."
          href="https://contractorcodex.com"
          ctaLabel="Start free →"
          external={true}
          titleHref="https://contractorcodex.com"
          accent={true}
        />
        <SoftwareCard
          variant="compact"
          name="SAMscout AI"
          chip="SaaS · Web app"
          tagline="The federal proposal team you can afford."
          oneLiner="Turn a SAM.gov opportunity into a reviewable, Shipley-grade proposal draft in minutes."
          href="https://app.samscout.ai"
          ctaLabel="Start free →"
          external={true}
          titleHref="https://samscout.ai"
          accent={true}
        />
        <SoftwareCard
          variant="compact"
          name="VA Disability Calc & Track"
          chip="iOS · iPhone & iPad"
          tagline="Know your rating. Track your claim."
          oneLiner="BVA-accurate combined-rating math and claim tracking, private on your device."
          href="https://apps.apple.com/us/app/va-disability-calc-track/id6748180691"
          ctaLabel="Download free →"
          external={true}
          titleHref="/va-disability-calc-track-app/"
          accent={false}
        />
      </div>
    </div>
  </section>

  {/* b. Front page — lead story + a rail of recent headlines. */}
  {lead && (
    <section class="border-b border-line bg-bg-primary px-6 py-10 md:py-14">
      <div class="mx-auto max-w-7xl">
        <div class="grid gap-8 lg:grid-cols-3">
          <div class="lg:col-span-2">
            <ArticleCard entry={lead} size="lead" loading="eager" />
          </div>
          <aside class="flex flex-col gap-3">
            <p class="eyebrow">Latest headlines</p>
            {beside.map((entry) => (
              <ArticleCard entry={entry} size="compact" loading="eager" />
            ))}
            <a
              href="/cyber-threat-intelligence/"
              class="group mt-1 block border border-intel/25 bg-intel/[0.06] p-4 transition-colors hover:border-intel/50"
            >
              <p class="eyebrow-intel">Downloads</p>
              <p class="mt-2 font-display text-base text-ink">IOC &amp; YARA rules</p>
              <p class="mt-1.5 text-sm leading-relaxed text-muted">
                Machine-readable indicators and YARA rules attached to reports. Hunt and block without re-typing.
              </p>
              <span class="mt-3 inline-block font-mono text-[11px] uppercase tracking-wider text-intel transition-colors group-hover:text-accent">
                Open the intel feed →
              </span>
            </a>
          </aside>
        </div>
      </div>
    </section>
  )}

  {/* c. Latest Threat Intelligence — rotating spotlight of this week's threats. */}
  <ThreatSpotlight entries={grid} />

  {/* d. Intelligence by region — the four nation-state tracks. */}
  {regions.length > 0 && (
    <section class="border-b border-line bg-bg-secondary px-6 py-14 md:py-16">
      <div class="mx-auto max-w-7xl">
        <div class="flex items-end justify-between gap-4">
          <div>
            <p class="eyebrow-intel">Nation-State Tracking</p>
            <h2 class="mt-3 font-display text-3xl uppercase tracking-[0.02em] text-ink md:text-4xl">
              Intelligence by Region
            </h2>
            <div class="accent-line mt-5"></div>
          </div>
          <a
            href="/anomalous-threat-actors/"
            class="hidden shrink-0 font-mono text-xs uppercase tracking-wider text-accent transition-colors hover:text-accent-bright sm:inline-flex"
          >
            Threat-actor profiles →
          </a>
        </div>

        <div class="mt-10 flex flex-col gap-12">
          {regions.map((region) => (
            <div>
              <div class="flex items-end justify-between gap-4 border-b border-line pb-4">
                <h3 class="flex items-center gap-3 font-display text-xl text-ink md:text-2xl">
                  <span class="text-2xl leading-none" aria-hidden="true">{region.flag}</span>
                  {region.label}
                </h3>
                <a
                  href={`/category/${region.slug}/`}
                  class="shrink-0 font-mono text-[11px] uppercase tracking-wider text-accent transition-colors hover:text-accent-bright"
                >
                  View all {region.short} intel →
                </a>
              </div>
              <div class="mt-6 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
                {region.articles.map((entry) => (
                  <ArticleCard entry={entry} />
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* e. Browse by category. */}
  {categories.length > 0 && (
    <section class="border-b border-line bg-bg-primary px-6 py-12">
      <div class="mx-auto max-w-7xl">
        <p class="eyebrow mb-5">Browse by category</p>
        <div class="flex flex-wrap gap-2.5">
          {categories.map((cat) => (
            <a
              href={cat.slug ? `/category/${cat.slug}/` : "/cyber-threat-intelligence/"}
              class="inline-flex items-center gap-2 border border-accent/35 bg-accent/[0.04] px-3 py-1.5 font-mono text-[11px] uppercase tracking-wider text-accent/90 transition-colors hover:border-accent hover:bg-accent/10 hover:text-accent"
            >
              {cat.name}
              <span class="text-accent/40">{cat.count}</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* f. Services & apps — secondary "we also build" band. */}
  <section class="border-b border-line bg-bg-secondary px-6 py-16">
    <div class="mx-auto max-w-7xl">
      <p class="eyebrow-muted">Beyond the feed</p>
      <div class="mt-3 flex flex-wrap items-end justify-between gap-4">
        <h2 class="font-display text-2xl uppercase tracking-[0.02em] text-ink md:text-3xl">
          Bulwark Black also builds
        </h2>
        <a
          href="/services/"
          class="font-mono text-xs uppercase tracking-wider text-accent transition-colors hover:text-accent-bright"
        >
          All services →
        </a>
      </div>

      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {serviceCategories.map((svc) => (
          <a href="/services/" class="group border border-line bg-bg-card p-5 card-lift">
            <span class="text-2xl" aria-hidden="true">{svc.icon}</span>
            <h3 class="mt-3 font-display text-base text-ink transition-colors group-hover:text-accent">
              {svc.title}
            </h3>
            <p class="mt-1.5 text-sm leading-relaxed text-muted line-clamp-3">{svc.summary}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* g. You may have missed — older stories back into rotation. */}
  {missed.length > 0 && (
    <section class="border-b border-line bg-bg-primary px-6 py-16">
      <div class="mx-auto max-w-7xl">
        <p class="eyebrow mb-5">You may have missed</p>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
          {missed.map((entry) => (
            <ArticleCard entry={entry} />
          ))}
        </div>
      </div>
    </section>
  )}

  {/* h. Newsletter. */}
  <NewsletterForm source="homepage" />
</BaseLayout>
