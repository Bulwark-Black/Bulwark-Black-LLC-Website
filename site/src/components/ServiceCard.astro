---
interface Props {
  icon: string;
  title: string;
  body: string;
  href: string;
  tag?: string;
}
const { icon, title, body, href, tag } = Astro.props;
---
<a href={href} class="group relative block overflow-hidden border border-line bg-bg-card p-7 card-lift">
  <span class="absolute left-0 top-0 h-full w-0.5 bg-accent/40 transition-all group-hover:w-1 group-hover:bg-accent"></span>
  <div class="flex items-start gap-4">
    <span class="text-2xl text-accent" aria-hidden="true">{icon}</span>
    <div class="min-w-0">
      <div class="flex items-center gap-3">
        <h3 class="font-display text-xl text-ink">{title}</h3>
        {tag && <span class="chip-intel shrink-0">{tag}</span>}
      </div>
      <p class="mt-2 text-sm leading-relaxed text-muted">{body}</p>
      <span class="mt-4 inline-block font-mono text-[11px] uppercase tracking-wider text-accent">
        Learn more →
      </span>
    </div>
  </div>
</a>
