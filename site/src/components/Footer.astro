---
import { site } from "@/lib/site";
const year = new Date().getFullYear();
---
<footer class="border-t border-line bg-bg-secondary text-muted">
  <div class="mx-auto grid max-w-7xl gap-6 px-6 py-14 md:grid-cols-4">
    <div class="border border-line p-5 md:p-6">
      <div class="flex items-center gap-2.5">
        <svg width="22" height="26" viewBox="0 0 26 30" fill="none" aria-hidden="true">
          <path d="M13 1L24 5v9c0 7-4.7 12.4-11 15C6.7 26.4 2 21 2 14V5l11-4z"
            fill="rgba(224,182,77,0.10)" stroke="#e0b64d" stroke-width="1.5" stroke-linejoin="round"/>
          <path d="M13 8v9M8.5 12.5h9" stroke="#e0b64d" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <p class="font-display text-lg font-semibold uppercase tracking-[0.14em] text-ink">
          Bulwark<span class="text-accent"> Black</span>
        </p>
      </div>
      <p class="mt-3 font-mono text-[11px] uppercase tracking-[0.2em] text-accent">
        Veteran-Owned · SDVOSB
      </p>
      <p class="mt-4 text-sm leading-relaxed">
        <span class="text-ink">{site.legalName}</span><br/>
        Cyber threat intelligence, custom software, and remote tech help.<br/>
        Remote across the United States.
      </p>
      <p class="mt-3 text-xs leading-relaxed text-muted/70">
        {site.address.label}:<br/>
        {site.address.street}<br/>
        {site.address.city}, {site.address.state} {site.address.zip}
      </p>
    </div>

    <div class="border border-line p-5 md:p-6">
      <p class="eyebrow-muted">Two front doors</p>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a href="/cyber-threat-intelligence/" class="hover:text-accent">Cyber Threat Intelligence</a></li>
        <li><a href="/services/" class="hover:text-accent">Tech Services &amp; Apps</a></li>
      </ul>
      <p class="eyebrow-muted mt-6">Services</p>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a href="/services/#websites-web-apps" class="hover:text-accent">Websites &amp; Web Apps</a></li>
        <li><a href="/services/#ios-apps" class="hover:text-accent">Custom iOS Apps</a></li>
        <li><a href="/services/#ai-automation" class="hover:text-accent">AI &amp; Automation</a></li>
        <li><a href="/services/#it-security" class="hover:text-accent">IT + Cybersecurity</a></li>
      </ul>
    </div>

    <div class="border border-line p-5 md:p-6">
      <p class="eyebrow-muted">Company</p>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a href="/about/" class="hover:text-accent">About</a></li>
        <li><a href="/products/" class="hover:text-accent">Software</a></li>
        <li><a href="/va-disability-calc-track-app/" class="hover:text-accent">VA Disability Calc &amp; Track</a></li>
        <li><a href="/community/" class="hover:text-accent">Community</a></li>
        <li><a href="/blog/" class="hover:text-accent">Blog</a></li>
        <li><a href="/how-i-work/" class="hover:text-accent">How I Work</a></li>
        <li><a href="/contact/" class="hover:text-accent">Contact</a></li>
        <li><a href="/privacy/" class="hover:text-accent">Privacy</a></li>
        <li><a href="/terms/" class="hover:text-accent">Terms</a></li>
        <li><a href="/va-disability-calc-track/" class="hover:text-accent">VA Calc Privacy Policy</a></li>
      </ul>
    </div>

    <div class="border border-line p-5 md:p-6">
      <p class="eyebrow-muted">For agencies &amp; primes</p>
      <ul class="mt-3 space-y-1 text-sm">
        <li><a href="/capability-statement/" class="hover:text-accent">Capability statement</a></li>
        <li>CAGE: <span class="font-mono text-ink">{site.contracting.cage}</span></li>
        <li>UEI: <span class="font-mono text-ink">{site.contracting.uei}</span></li>
        <li>{site.contracting.certifications.join(" · ")}</li>
      </ul>
      <p class="mt-4 text-xs">
        <a href={`mailto:${site.email}`} class="text-accent hover:underline">{site.email}</a>
      </p>

      <p class="eyebrow-muted mt-6">Connect</p>
      <ul class="mt-3 flex items-center gap-4 text-sm">
        <li>
          <a
            href="https://www.linkedin.com/in/albert-lascola"
            class="inline-flex items-center gap-2 text-muted hover:text-accent"
            rel="noopener me"
            aria-label="Albert LaScola on LinkedIn"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M4.98 3.5C4.98 4.88 3.86 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1 4.98 2.12 4.98 3.5zM.5 8h4V24h-4V8zM7.5 8h3.8v2.2h.05c.53-1 1.83-2.05 3.77-2.05 4.04 0 4.78 2.66 4.78 6.12V24h-4v-7.5c0-1.79-.03-4.1-2.5-4.1-2.5 0-2.88 1.95-2.88 3.96V24h-4V8z"/>
            </svg>
            LinkedIn
          </a>
        </li>
        <li>
          <a
            href="https://github.com/AlbertL7"
            class="inline-flex items-center gap-2 text-muted hover:text-accent"
            rel="noopener me"
            aria-label="AlbertL7 on GitHub"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.9.58.1.79-.25.79-.56 0-.28-.01-1.02-.02-2-3.2.69-3.87-1.54-3.87-1.54-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.69 1.24 3.35.95.1-.74.4-1.24.72-1.53-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.47.11-3.06 0 0 .96-.31 3.15 1.18a10.95 10.95 0 0 1 5.74 0c2.19-1.49 3.15-1.18 3.15-1.18.62 1.59.23 2.77.11 3.06.74.81 1.18 1.84 1.18 3.1 0 4.43-2.69 5.4-5.25 5.69.41.35.77 1.05.77 2.12 0 1.53-.01 2.77-.01 3.14 0 .31.21.67.8.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"/>
            </svg>
            GitHub
          </a>
        </li>
      </ul>
    </div>
  </div>
  <div class="border-t border-line px-6 py-5 text-center text-xs">
    <p>© {year} {site.legalName}. All rights reserved.</p>
    <p class="mt-2">
      <a href="/privacy/" class="hover:text-accent">Privacy</a>
      <span class="mx-2 text-muted/50">·</span>
      <a href="/terms/" class="hover:text-accent">Terms</a>
    </p>
  </div>
</footer>
