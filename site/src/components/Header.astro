---
import { site } from "@/lib/site";
const nav = site.nav;

// Active-page indicator: highlight the top-level item whose own href — or any of
// its internal children — matches the current path. Trailing slashes normalized.
const path = Astro.url.pathname.replace(/\/+$/, "") || "/";
function itemHrefs(item: (typeof nav)[number]): string[] {
  const list: string[] = [];
  if (item.href) list.push(item.href);
  for (const c of item.children ?? []) if (!c.external) list.push(c.href);
  return list.map((h) => h.replace(/\/+$/, "") || "/");
}
function isActive(item: (typeof nav)[number]): boolean {
  if (path === "/") return false;
  return itemHrefs(item).some((h) => h !== "/" && (path === h || path.startsWith(h + "/")));
}
---
<header class="sticky top-0 z-40 border-b border-line bg-bg-primary/85 backdrop-blur">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-6 py-4">
    <a href="/" class="group flex items-center gap-2.5" aria-label={`${site.name} home`}>
      <img src="/logo.png" alt="Bulwark Black" width="40" height="40" class="h-10 w-10 shrink-0 object-contain" />
      <span class="font-display text-lg font-semibold uppercase tracking-[0.14em] text-ink">
        Bulwark<span class="text-accent"> Black</span>
      </span>
    </a>

    <nav class="hidden items-center lg:flex" aria-label="Primary">
      {nav.map((item, i) => {
        const active = isActive(item);
        return item.children && item.children.length > 0 ? (
          <div class="mega relative">
            <a
              href={item.href}
              class:list={[
                "mega-trigger flex items-center gap-1 border-b-2 px-3 py-2 text-sm transition-colors",
                active ? "border-intel text-ink" : "border-transparent text-ink/80 hover:text-ink",
              ]}
              aria-haspopup="true"
              aria-expanded="false"
              aria-current={active ? "page" : undefined}
            >
              {item.label}
              <svg class="mega-caret h-3 w-3 text-muted/60 transition-transform" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M3 4.5 6 7.5 9 4.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
            <div class={`mega-panel absolute top-full ${i >= nav.length - 2 ? "right-0" : "left-0"} z-50 pt-2`}>
              <ul class="min-w-[15rem] border border-line bg-bg-secondary p-1.5 shadow-2xl shadow-black/40">
                {item.children.map((c) => (
                  <li>
                    <a
                      href={c.href}
                      target={c.external ? "_blank" : undefined}
                      rel={c.external ? "noopener" : undefined}
                      class="flex items-center justify-between gap-2 border-l-2 border-transparent px-3 py-2 text-sm text-ink/80 transition-colors hover:border-intel/40 hover:bg-white/[0.04] hover:text-ink"
                    >
                      {c.label}
                      {c.external && <span class="text-[11px] text-muted/60" aria-hidden="true">↗</span>}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ) : (
          <a
            href={item.href}
            class:list={[
              "border-b-2 px-3 py-2 text-sm transition-colors",
              active ? "border-intel text-ink" : "border-transparent text-ink/80 hover:text-ink",
            ]}
            aria-current={active ? "page" : undefined}
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <div class="hidden items-center gap-3 lg:flex">
      <a
        href="/cyber-threat-intelligence/"
        class="inline-flex items-center gap-1.5 border border-intel/30 bg-intel/10 px-3 py-2 font-mono text-[11px] uppercase tracking-wider text-intel transition-colors hover:bg-intel/20"
      >
        Threat Intel →
      </a>
      <a href="/contact/" class="btn-primary !py-2 !text-xs">Work with us →</a>
    </div>

    <button id="nav-toggle" aria-label="Open menu" aria-controls="mobile-nav" aria-expanded="false" class="text-ink lg:hidden">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </div>

  <div id="mobile-nav" class="hidden border-t border-line bg-bg-secondary lg:hidden">
    <nav class="mx-auto flex max-w-7xl flex-col px-6 py-4" aria-label="Mobile">
      {nav.map((item) => (
        item.children && item.children.length > 0 ? (
          <div class="acc border-b border-line/60">
            <button
              type="button"
              class="acc-trigger flex w-full items-center justify-between py-3 text-left text-sm font-medium text-ink"
              aria-expanded="false"
            >
              {item.label}
              <svg class="acc-caret h-4 w-4 text-muted transition-transform" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M4 6 8 10 12 6" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </button>
            <div class="acc-panel hidden pb-2">
              {item.href && (
                <a href={item.href} class="block py-2 pl-3 text-sm text-muted hover:text-ink">
                  All {item.label} →
                </a>
              )}
              {item.children.map((c) => (
                <a
                  href={c.href}
                  target={c.external ? "_blank" : undefined}
                  rel={c.external ? "noopener" : undefined}
                  class="flex items-center gap-1.5 py-2 pl-3 text-sm text-ink/70 hover:text-ink"
                >
                  {c.label}
                  {c.external && <span class="text-[11px] text-muted/60" aria-hidden="true">↗</span>}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a href={item.href} class="border-b border-line/60 py-3 text-sm font-medium text-ink hover:text-ink">
            {item.label}
          </a>
        )
      ))}
      <a href="/contact/" class="btn-primary mt-4 justify-center !text-xs">Work with us →</a>
    </nav>
  </div>
</header>

<style>
  /* Desktop dropdowns: reveal on hover and on keyboard focus within the group. */
  .mega-panel {
    opacity: 0;
    visibility: hidden;
    transform: translateY(4px);
    pointer-events: none;
    transition: opacity 0.15s ease, transform 0.15s ease, visibility 0.15s;
  }
  .mega:hover .mega-panel,
  .mega:focus-within .mega-panel {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }
  .mega:hover .mega-caret,
  .mega:focus-within .mega-caret {
    transform: rotate(180deg);
  }
  @media (prefers-reduced-motion: reduce) {
    .mega-panel { transition: none; }
  }
</style>

<script>
  // Mobile hamburger.
  const toggle = document.getElementById("nav-toggle");
  const panel = document.getElementById("mobile-nav");
  toggle?.addEventListener("click", () => {
    const open = panel?.classList.toggle("hidden");
    toggle.setAttribute("aria-expanded", String(open === false));
  });

  // Mobile accordion groups.
  document.querySelectorAll<HTMLElement>("#mobile-nav .acc").forEach((group) => {
    const trigger = group.querySelector<HTMLButtonElement>(".acc-trigger");
    const body = group.querySelector<HTMLElement>(".acc-panel");
    const caret = group.querySelector<SVGElement>(".acc-caret");
    trigger?.addEventListener("click", () => {
      const nowOpen = body?.classList.toggle("hidden") === false;
      trigger.setAttribute("aria-expanded", String(nowOpen));
      if (caret) caret.style.transform = nowOpen ? "rotate(180deg)" : "";
    });
  });

  // Keep aria-expanded truthful on the desktop dropdown triggers.
  document.querySelectorAll<HTMLElement>(".mega").forEach((group) => {
    const trigger = group.querySelector<HTMLElement>(".mega-trigger");
    const set = (v: boolean) => trigger?.setAttribute("aria-expanded", String(v));
    group.addEventListener("mouseenter", () => set(true));
    group.addEventListener("mouseleave", () => set(false));
    group.addEventListener("focusin", () => set(true));
    group.addEventListener("focusout", (e) => {
      if (!group.contains(e.relatedTarget as Node)) set(false);
    });
    group.addEventListener("keydown", (e) => {
      if ((e as KeyboardEvent).key === "Escape") {
        set(false);
        (document.activeElement as HTMLElement)?.blur();
      }
    });
  });
</script>
