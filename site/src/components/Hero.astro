---
interface Props {
  eyebrow?: string;
  titleTop: string;
  titleAccent?: string;
  tagline?: string;
  subtitle: string;
  primary: { label: string; href: string };
  secondary?: { label: string; href: string };
  markers?: string[];
}
const {
  eyebrow,
  titleTop,
  titleAccent,
  tagline,
  subtitle,
  primary,
  secondary,
  markers = [],
} = Astro.props;
---
<section class="relative overflow-hidden border-b border-line bg-bg-primary px-6 pb-24 pt-20 md:pt-28">
  <!-- Section-scoped ops grid + gold glow (never page-height) -->
  <div class="grid-bg pointer-events-none absolute inset-0"></div>
  <div class="pointer-events-none absolute left-1/2 top-0 -z-0 h-[380px] w-[720px] max-w-full -translate-x-1/2 rounded-full bg-accent/30 blur-[120px] animate-pulse-glow"></div>

  <div class="relative z-10 mx-auto max-w-4xl text-center">
    {eyebrow && (
      <span class="inline-flex items-center gap-2 border border-line bg-white/[0.02] px-4 py-1.5 font-mono text-[11px] uppercase tracking-[0.24em] text-accent animate-fade-up [animation-delay:0.05s]">
        <span class="relative flex h-1.5 w-1.5">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-intel/70"></span>
          <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-intel"></span>
        </span>
        {eyebrow}
      </span>
    )}

    <h1 class="mt-8 font-display text-5xl font-semibold uppercase tracking-[0.06em] text-ink md:text-8xl animate-fade-up [animation-delay:0.12s]">
      {titleTop}
      {titleAccent && <span class="block text-accent">{titleAccent}</span>}
    </h1>

    {tagline && (
      <p class="mx-auto mt-6 max-w-2xl font-mono text-sm uppercase tracking-[0.18em] text-muted animate-fade-up [animation-delay:0.2s]">
        {tagline}
      </p>
    )}

    <p class="mx-auto mt-5 max-w-2xl text-lg font-light leading-relaxed text-ink/80 animate-fade-up [animation-delay:0.28s]">
      {subtitle}
    </p>

    <div class="mt-10 flex flex-wrap items-center justify-center gap-4 animate-fade-up [animation-delay:0.36s]">
      <a href={primary.href} class="btn-primary">{primary.label} →</a>
      {secondary && <a href={secondary.href} class="btn-outline">{secondary.label} →</a>}
    </div>

    {markers.length > 0 && (
      <ul class="mx-auto mt-12 flex max-w-2xl flex-wrap items-center justify-center gap-x-6 gap-y-2 border-t border-line pt-6 font-mono text-[11px] uppercase tracking-[0.2em] text-muted animate-fade-up [animation-delay:0.44s]">
        {markers.map((m) => (
          <li class="flex items-center gap-2">
            <span class="text-accent/70">▹</span>{m}
          </li>
        ))}
      </ul>
    )}
  </div>
</section>
