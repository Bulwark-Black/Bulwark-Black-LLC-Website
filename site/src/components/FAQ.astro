---
interface Item {
  q: string;
  a: string;
}
interface Props {
  eyebrow?: string;
  title?: string;
  items: Item[];
}
const { eyebrow = "FAQ", title = "Common questions.", items } = Astro.props;
---
<section class="bg-bg-secondary px-6 py-20">
  <div class="mx-auto max-w-3xl">
    <p class="text-[11px] uppercase tracking-[3px] text-accent">{eyebrow}</p>
    <h2 class="mt-3 font-display text-3xl text-ink md:text-4xl">{title}</h2>
    <div class="accent-line mt-6"></div>
    <ul class="mt-8 space-y-3">
      {items.map((it) => (
        <li class="border border-accent/15 bg-bg-card">
          <details class="group">
            <summary class="flex cursor-pointer items-center justify-between gap-4 px-5 py-4 text-left">
              <span class="font-display text-lg text-ink">{it.q}</span>
              <span class="text-accent transition group-open:rotate-45 text-xl leading-none">+</span>
            </summary>
            <div class="px-5 pb-5 text-muted leading-relaxed">{it.a}</div>
          </details>
        </li>
      ))}
    </ul>
  </div>
</section>
