---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: "left" | "center";
}
const { eyebrow, title, subtitle, align = "left" } = Astro.props;
const wrap = align === "center" ? "text-center mx-auto" : "";
---
<header class={`mb-10 ${wrap}`}>
  {eyebrow && (
    <p class="mb-3 text-[11px] uppercase tracking-[3px] text-accent">{eyebrow}</p>
  )}
  <h2 class="font-display text-3xl md:text-5xl text-ink">{title}</h2>
  {subtitle && <p class="mt-4 max-w-2xl text-muted">{subtitle}</p>}
  <div class={`accent-line mt-6 ${align === "center" ? "mx-auto" : ""}`}></div>
</header>
