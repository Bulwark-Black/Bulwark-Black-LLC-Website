---
// Shared product card used on the Software page (full) and the homepage band (compact).
// One copy source: the Software page and the homepage reuse this same component.
interface Props {
  name: string;
  chip: string;
  tagline: string;
  oneLiner: string;
  features?: string[];
  pricing?: string;
  href: string;
  ctaLabel: string;
  external?: boolean;
  secondaryHref?: string;
  secondaryLabel?: string;
  accent?: boolean;
  titleHref?: string;
  variant?: "full" | "compact";
}
const {
  name,
  chip,
  tagline,
  oneLiner,
  features = [],
  pricing,
  href,
  ctaLabel,
  external,
  secondaryHref,
  secondaryLabel,
  accent = false,
  titleHref,
  variant = "full",
} = Astro.props;

const isExt = (u?: string) => !!u && /^https?:\/\//.test(u);
const ctaExternal = external ?? isExt(href);
const titleExternal = isExt(titleHref);
const secondaryExternal = isExt(secondaryHref);
const compact = variant === "compact";

const primaryCls = compact
  ? (accent ? "btn-primary !py-2 !text-xs" : "btn-outline !py-2 !text-xs")
  : "btn-primary";
const wordmarkSize = compact ? "text-xl" : "text-2xl";
const taglineSize = compact ? "text-base" : "text-lg";
---
<article
  class:list={[
    "card-lift flex flex-col bg-bg-card",
    accent ? "border border-accent/30" : "border border-line",
    compact ? "p-6" : "p-8",
  ]}
>
  {accent && <div class="accent-line mb-5"></div>}

  <div class="flex items-start justify-between gap-3">
    {titleHref ? (
      <a
        href={titleHref}
        target={titleExternal ? "_blank" : undefined}
        rel={titleExternal ? "noopener" : undefined}
        class={`font-display ${wordmarkSize} font-semibold text-ink transition-colors hover:text-accent`}
      >
        {name}
      </a>
    ) : (
      <h3 class={`font-display ${wordmarkSize} font-semibold text-ink`}>{name}</h3>
    )}
    <span class="shrink-0 border border-intel/30 px-2 py-0.5 font-mono text-[10px] uppercase tracking-wider text-intel">
      {chip}
    </span>
  </div>

  <p class={`mt-3 font-display ${taglineSize} text-accent`}>{tagline}</p>
  <p class="mt-2 text-sm leading-relaxed text-muted">{oneLiner}</p>

  {!compact && features.length > 0 && (
    <ul class="mt-5 space-y-2.5">
      {features.map((f) => (
        <li class="flex gap-2.5 text-sm leading-relaxed">
          <span class="mt-0.5 shrink-0 font-mono text-intel" aria-hidden="true">▸</span>
          <span class="text-ink/90">{f}</span>
        </li>
      ))}
    </ul>
  )}

  <div class="mt-auto pt-6">
    {pricing && <p class="font-mono text-[11px] leading-relaxed text-muted">{pricing}</p>}
    <div class:list={["flex flex-wrap items-center gap-3", pricing && "mt-4"]}>
      <a
        href={href}
        target={ctaExternal ? "_blank" : undefined}
        rel={ctaExternal ? "noopener" : undefined}
        class={primaryCls}
      >
        {ctaLabel}
      </a>
      {secondaryHref && secondaryLabel && (
        <a
          href={secondaryHref}
          target={secondaryExternal ? "_blank" : undefined}
          rel={secondaryExternal ? "noopener" : undefined}
          class="btn-outline"
        >
          {secondaryLabel}
        </a>
      )}
    </div>
  </div>
</article>
