---
import NetworkBackground from "./NetworkBackground.astro";
---
<section class="hero">
  <NetworkBackground />

  <div class="hero-brand">
    <svg width="40" height="46" viewBox="0 0 26 30" fill="none" aria-hidden="true">
      <path
        d="M13 1L24 5v9c0 7-4.7 12.4-11 15C6.7 26.4 2 21 2 14V5l11-4z"
        fill="rgba(224,182,77,0.10)"
        stroke="#e0b64d"
        stroke-width="1.5"
        stroke-linejoin="round"
      ></path>
      <path
        d="M13 8v9M8.5 12.5h9"
        stroke="#e0b64d"
        stroke-width="1.5"
        stroke-linecap="round"
      ></path>
    </svg>
    <span class="hero-wordmark">Bulwark <span class="gold">Black</span></span>
  </div>

  <h1>
    The cyber and software team<br />
    your business can <span class="highlight">actually reach.</span>
  </h1>

  <p class="hero-sub">
    Daily cyber threat intelligence, custom web and iOS apps, AI setup, and
    honest remote tech help &mdash; veteran-owned, SDVOSB, built by the person
    who ships it.
  </p>

  <div class="hero-buttons">
    <a href="/cyber-threat-intelligence/" class="btn btn-primary btn-large"
      >Explore Threat Intel &rarr;</a
    >
    <a href="/contact/" class="btn btn-secondary btn-large">Work with us</a>
  </div>

  <p class="hero-note">Free daily intelligence. No login required.</p>
</section>
